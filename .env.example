# Copy to .env and adjust. Consumed by docker-compose.yml.

# Published image + tag to run. Pin to a release (e.g. 0.1.0) in production;
# `latest` is fine for trying it out.
CUEBREAKER_IMAGE=semsemyonoff/cuebreaker
CUEBREAKER_TAG=latest

# Host port the UI/API is exposed on (container always serves on 5000).
CUEBREAKER_HTTP_PORT=8080

# Host paths bind-mounted into the container.
#   input/  — your unsplit albums, one dir per album (single FLAC + its CUE).
#             Mounted read-only; cueBreaker never touches the source files.
#   output/ — where the split, tagged tracks are written. Must be writable by
#             the UID/GID below.
CUEBREAKER_INPUT_PATH=./input
CUEBREAKER_OUTPUT_PATH=./output

# Run the container as this user, so split tracks are owned by you rather than
# by root. `id -u` / `id -g` on the host.
CUEBREAKER_UID=1000
CUEBREAKER_GID=1000

# Container timezone (affects logs / timestamps).
TZ=UTC
